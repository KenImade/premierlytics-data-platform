FROM python:3.13-slim-trixie

# Install uv
COPY --from=ghcr.io/astral-sh/uv:0.10.7 /uv /uvx /bin/

ENV UV_NO_DEV=1
ENV PYTHONUNBUFFERED=1
ENV DAGSTER_HOME=/opt/dagster/dagster_home

# Create Dagster home
RUN mkdir -p $DAGSTER_HOME

# Create directories for local storage and logs
RUN mkdir -p \
    /opt/dagster/storage \
    /opt/dagster/compute_logs

# Install Dagster runtime dependencies (pinned)
COPY docker/dagster/requirements.txt /tmp/requirements.txt
RUN uv pip install -r /tmp/requirements.txt --system

# Copy Dagster config
COPY docker/dagster/dagster.yaml docker/dagster/workspace.yaml $DAGSTER_HOME

WORKDIR $DAGSTER_HOME